# Docker Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Database
POSTGRES_USER=workmine
POSTGRES_PASSWORD=workmine
POSTGRES_DB=workmine

# GitHub Integration (Optional)
GITHUB_TOKEN=

# Analysis (Optional)
SKIP_ANALYSIS_CACHE=true

# OpenAI Integration (Optional - for AI-powered resume generation)
OPENAI_API_KEY=
AI_RESUME_GENERATION=True
AI_MODEL=gpt-4o-mini