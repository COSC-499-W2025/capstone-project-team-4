# Database Configuration
DATABASE_URL=postgresql://workmine:workmine@db:5432/workmine

# CORS (must be valid JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# Analysis Settings
# Skip cache for analysis results (useful for testing)
SKIP_ANALYSIS_CACHE=true

# Enable library and tool detection during upload (set to false to defer to async endpoint)
ENABLE_LIBRARY_TOOL_DETECTION=true

# Enable framework detection during upload (set to false to defer to async endpoint)
ENABLE_FRAMEWORK_DETECTION=true